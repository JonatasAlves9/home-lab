# =============================================================================
# Configurações do Notebook (Nó 1 — sempre ligado)
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git
# =============================================================================

# --- Nextcloud ---
# Usuário administrador criado na primeira inicialização
NEXTCLOUD_ADMIN_USER=admin
# Senha forte para o admin — mínimo 12 caracteres recomendado
NEXTCLOUD_ADMIN_PASSWORD=troque_esta_senha

# --- Pi-hole ---
# Senha para acessar a interface web do Pi-hole em http://<ip>:8082/admin
PIHOLE_PASSWORD=troque_esta_senha

# --- Tailscale ---
# Gere uma chave em: https://login.tailscale.com/admin/settings/keys
# Use uma chave reusável (reusable) para facilitar reautenticações
TS_AUTHKEY=tskey-auth-XXXXXXXXX

# --- Wake on LAN (Desktop) ---
# Endereço MAC da placa de rede do Desktop (formato AA:BB:CC:DD:EE:FF)
# Encontre com: ip link show | grep ether (no Desktop)
DESKTOP_MAC=AA:BB:CC:DD:EE:FF
# Endereço IP local do Desktop (fixe um IP no roteador via DHCP estático)
DESKTOP_IP=192.168.1.X
