# =============================================================================
# Configurações do Desktop (Nó 2 — sob demanda)
# Copie este arquivo para .env e ajuste se necessário
# Os valores padrão já são adequados para a maioria das instalações
# =============================================================================

# Fuso horário dos containers
TZ=America/Recife

# UID e GID do usuário que possui os arquivos de mídia
# Verifique com: id $USER
PUID=1000
PGID=1000
